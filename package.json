{
  "name": "spacelycms",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/server",
    "packages/admin",
    "packages/astro",
    "packages/create-spacely",
    "examples/college-site"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/server",
    "dev:admin": "npm run dev --workspace=packages/admin",
    "dev:site": "npm run dev --workspace=examples/college-site",
    "build": "npm run build --workspace=packages/server && npm run build --workspace=packages/admin",
    "build:server": "npm run build --workspace=packages/server",
    "build:admin": "npm run build --workspace=packages/admin",
    "build:site": "npm run build --workspace=examples/college-site",
    "test": "npm run test --workspace=packages/server",
    "db:migrate": "npm run db:migrate --workspace=packages/server",
    "db:seed": "npm run db:seed --workspace=packages/server",
    "db:generate": "npm run db:generate --workspace=packages/server"
  }
}
