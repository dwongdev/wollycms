---
import RichTextRenderer from '@wollycms/astro/components/RichText.astro';
import type { BlockProps } from '@wollycms/astro';

interface Props extends BlockProps {
  fields: {
    heading?: string;
    items: Array<{ title: string; body: any }>;
    default_open?: boolean;
  };
}

const { fields } = Astro.props;

function isRichText(body: any): boolean {
  return body && typeof body === 'object' && body.type === 'doc';
}
---

<div class="block block-accordion">
  {fields.heading && <h3 class="accordion-heading">{fields.heading}</h3>}
  {fields.items.map((item, i) => (
    <details class="accordion-item" open={fields.default_open && i === 0}>
      <summary class="accordion-title">{item.title}</summary>
      <div class="accordion-body">
        {isRichText(item.body) ? (
          <RichTextRenderer content={item.body} />
        ) : (
          <p>{String(item.body)}</p>
        )}
      </div>
    </details>
  ))}
</div>
