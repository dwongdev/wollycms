---
import Layout from '../layouts/Default.astro';
import BlockRenderer from '@spacelycms/astro/components/BlockRenderer.astro';
import { spacely } from '../lib/spacely';
import * as blockComponents from '../lib/blocks';

const page = await spacely.pages.getBySlug('home');
const [mainMenu, footerMenu, config] = await Promise.all([
  spacely.menus.get('main'),
  spacely.menus.get('footer'),
  spacely.config.get(),
]);

const regions = page.regions ?? {};
const heroBlocks = regions.hero ?? [];
const contentBlocks = regions.content ?? [];
const featureBlocks = regions.features ?? [];
const bottomBlocks = regions.bottom ?? [];

// Extract hero data from blocks for the split layout
const heroImage = heroBlocks.find((b: any) => b.block_type === 'image');
const heroCta = heroBlocks.find((b: any) => b.block_type === 'cta_button');
const heroImgSrc = heroImage?.fields?.image
  ? (typeof heroImage.fields.image === 'number'
    ? spacely.media.url(heroImage.fields.image, 'large')
    : String(heroImage.fields.image))
  : null;
const hasHero = !!(page.fields.tagline || heroImgSrc);
---

<Layout title={config?.siteName ?? page.title} menu={mainMenu} footerMenu={footerMenu} config={config}>
  {hasHero && (
    <section class="hero-region hero-home">
      <div class="container hero-split">
        <div class="hero-text">
          {page.fields.hero_eyebrow && (
            <span class="hero-eyebrow">{page.fields.hero_eyebrow}</span>
          )}
          {page.fields.tagline && (
            <h1 class="hero-title">{page.fields.tagline}</h1>
          )}
          {page.fields.hero_description && (
            <p class="hero-description">{page.fields.hero_description}</p>
          )}
          {heroCta && (
            <a
              href={heroCta.fields.url}
              class:list={['cta-button', `cta-${heroCta.fields.style ?? 'secondary'}`]}
            >
              {heroCta.fields.text}
            </a>
          )}
        </div>
        {heroImgSrc && (
          <div class="hero-image-wrap">
            <img
              src={heroImgSrc}
              alt={heroImage?.fields?.alt ?? ''}
              class="hero-image"
              loading="eager"
            />
          </div>
        )}
      </div>
    </section>
  )}

  {contentBlocks.length > 0 && (
    <section class="content-region">
      <div class="container">
        <BlockRenderer blocks={contentBlocks} region="content" components={blockComponents} />
      </div>
    </section>
  )}

  {featureBlocks.length > 0 && (
    <section class="features-region">
      <div class="container">
        <BlockRenderer blocks={featureBlocks} region="features" components={blockComponents} />
      </div>
    </section>
  )}

  {bottomBlocks.length > 0 && (
    <section class="bottom-region">
      <div class="container">
        <BlockRenderer blocks={bottomBlocks} region="bottom" components={blockComponents} />
      </div>
    </section>
  )}
</Layout>
