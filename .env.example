# WollyCMS Environment Variables
# Copy to .env and fill in your values

# Database (SQLite or PostgreSQL)
DATABASE_URL=sqlite:./data/wolly.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/wolly

# Server
PORT=4321
HOST=localhost
NODE_ENV=development

# Auth
JWT_SECRET=change-me-in-production

# CORS (comma-separated origins, or * for all)
# WARNING: CORS_ORIGINS=* is for development only. In production, restrict to your domains:
# CORS_ORIGINS=https://your-site.com,https://admin.your-site.com
CORS_ORIGINS=*

# Rate Limiting (auth endpoints)
RATE_LIMIT_AUTH=10
RATE_LIMIT_WINDOW_MS=900000

# Media Storage
MEDIA_STORAGE=local
MEDIA_DIR=./uploads
# For Cloudflare R2 (recommended for production):
# MEDIA_STORAGE=s3
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_BUCKET=wolly-media
# S3_REGION=auto
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_PUBLIC_URL=https://media.yoursite.com

# Astro Integration (for live preview)
ASTRO_PREVIEW_URL=http://localhost:4322

# Site URL (for webhooks, preview links)
SITE_URL=http://localhost:4322
