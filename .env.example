# SpacelyCMS Environment Variables
# Copy to .env and fill in your values

# Database
DATABASE_URL=sqlite:./data/spacely.db
# DATABASE_URL=postgres://user:pass@localhost:5432/spacely

# Server
PORT=4321
HOST=localhost
NODE_ENV=development

# Media Storage
MEDIA_STORAGE=local
# MEDIA_STORAGE=s3
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT=

# Auth
JWT_SECRET=change-me-in-production
SESSION_SECRET=change-me-in-production

# Astro Integration (for live preview)
ASTRO_PREVIEW_URL=http://localhost:4322
