        "subheading": "Replicate Drupal Views in WollyCMS",
        "background_image": ""
      },
      "isReusable": false,
      "createdAt": "2026-01-01T00:00:00.000Z",
      "updatedAt": "2026-01-01T00:00:00.000Z"
    },
    {
      "id": 17,
      "typeId": 1,
      "title": "Article 3 Content",
      "fields": {
        "body": {
          "type": "doc",
          "content": [
